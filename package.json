{
  "name": "@devs-des1re/djs-kit",
  "version": "1.3.0",
  "description": "Scaffold production-ready discord.js v14 bot projects",
  "type": "module",
  "bin": {
    "djs-kit": "./dist/index.js",
    "djskit": "./dist/index.js"
  },
  "files": [
    "dist",
    "src/templates",
    "!dist/tests"
  ],
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "build": "tsc",
    "sync": "node scripts/sync.js",
    "build:all": "tsc && npm run sync",
    "dev": "tsx bin/djs-kit.ts",
    "start": "node dist/bin/djs-kit.js",
    "test": "npm run build && node --test dist/tests/*.test.js"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "commander": "^12.1.0",
    "discord.js": "^14.26.4",
    "fast-glob": "^3.3.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
