# Copy this file to .env and fill in your bot settings
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here
DISCORD_GUILD_ID=your_server_id_here
# Optional comma-separated lists
DISCORD_GUILD_IDS=
BOT_OWNER_IDS=
# Optional separate signing key for component custom IDs
DJSKIT_COMPONENT_SECRET=
# Required when using sqlite/postgres/mysql/mongo/redis presets
DATABASE_URL=
# Optional logging channels
LOG_CHANNEL_ID=
MOD_AUDIT_CHANNEL_ID=
